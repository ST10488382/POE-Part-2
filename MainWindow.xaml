<Window x:Class="demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demo"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Chatbot"
        Height="550" Width="850"
        Background="#F0F4FF"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- ── HOME GRID ── -->
        <Grid x:Name="home_grid" Visibility="Visible" Background="#F0F4FF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <Image Source="/logo.jpg"
                       Height="160" Width="160"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

                <TextBlock Text="Cybersecurity Awareness Chatbot"
                           FontSize="22"
                           FontFamily="Segoe UI Semibold"
                           Foreground="#1E293B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Your personal guide to staying safe online"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <Button Height="42" Width="220"
                        Content="Get Started"
                        Click="proceed"
                        Cursor="Hand"
                        FontSize="14"
                        FontFamily="Segoe UI Semibold"
                        Foreground="White"
                        Background="#2563EB"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Grid>

        <!-- ── USERNAME GRID ── -->
        <Grid x:Name="username_grid" Visibility="Hidden" Background="#F0F4FF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">

                <Image Source="/logo.jpg"
                       Height="120" Width="120"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

                <TextBlock Text="What's your name?"
                           FontSize="20"
                           FontFamily="Segoe UI Semibold"
                           Foreground="#1E293B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="I'll use it to personalise your experience"
                           FontSize="12"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBox x:Name="usernames_input"
                         Height="42"
                         FontSize="13"
                         FontFamily="Segoe UI"
                         Background="White"
                         Foreground="Black"
                         BorderBrush="#2563EB"
                         BorderThickness="2"
                         Padding="12,10"
                         Margin="0,0,0,8"/>

                <TextBlock x:Name="error_label"
                           Text="⚠ Please enter your name to continue."
                           FontSize="12"
                           Foreground="#DC2626"
                           Visibility="Hidden"
                           Margin="4,0,0,10"/>

                <Button Height="42"
                        Content="Continue"
                        Click="submit_name"
                        Cursor="Hand"
                        FontSize="14"
                        FontFamily="Segoe UI Semibold"
                        Foreground="White"
                        Background="#2563EB"
                        BorderThickness="0"
                        Margin="0,6,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Grid>

        <!-- ── CHAT GRID ── -->
        <Grid x:Name="chat_grid" Visibility="Hidden" Background="#F0F4FF">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="68"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#CBD5E1"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0">
                    <Image Source="/logo.jpg"
                           Height="36" Width="36"
                           Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CyberGuard Chatbot"
                                   FontSize="14"
                                   FontFamily="Segoe UI Semibold"
                                   Foreground="#1E293B"/>
                        <TextBlock x:Name="chat_subtitle"
                                   Text="Online"
                                   FontSize="11"
                                   Foreground="#16A34A"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Messages list -->
            <ListView x:Name="chats"
                      Grid.Row="1"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="12,8"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

            <!-- Input bar -->
            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#CBD5E1"
                    BorderThickness="0,1,0,0"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="question"
                             Grid.Column="0"
                             Height="44"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             Background="White"
                             Foreground="Black"
                             BorderBrush="#2563EB"
                             BorderThickness="2"
                             Padding="12,10"
                             Margin="0,0,10,0"/>

                    <Button Grid.Column="1"
                            Height="44" Width="90"
                            Content="Send"
                            Click="send"
                            Cursor="Hand"
                            FontSize="13"
                            FontFamily="Segoe UI Semibold"
                            Foreground="White"
                            Background="#2563EB"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>